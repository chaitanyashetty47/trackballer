# Supabase (public — browser + server components)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Auth: Supabase → Authentication → URL Configuration
# Site URL (OAuth return): http://localhost:3000 (prod: https://<your-vercel-domain>)
# Redirect URLs: same origin root; optional http://localhost:3000/auth/callback

# Supabase service role — server-only; required for catalog sync writes
SUPABASE_SECRET_KEY=your-secret-key
# Legacy alias (optional)
# SUPABASE_SERVICE_ROLE_KEY=

# API-Football (server-only)
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_KEY=your-api-sports-key
API_FOOTBALL_LEAGUE_ID=1
API_FOOTBALL_SEASON=2022
# Season for POST /api/admin/sync/clubs/top-leagues (defaults to API_FOOTBALL_SEASON or 2024)
# API_FOOTBALL_CLUBS_SEASON=2024

# Protect admin sync routes (Postman: Authorization: Bearer <secret>)
SYNC_ADMIN_SECRET=change-me-to-a-long-random-string
